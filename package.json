{
    "name": "uptime-monitor-root",
    "private": true,
    "scripts": {
        "prepare": "git config core.hooksPath .githooks || true",
        "check:paths": "bash ./scripts/check-paths.sh all",
        "check:contracts": "bash ./scripts/check-contracts.sh",
        "loadtest:agent-results": "node ./scripts/loadtest-agent-results.mjs",
        "build:shared": "npm --prefix packages/shared run build && npm --prefix packages/checker run build",
        "build:server": "npm --prefix server run build",
        "build:client": "npm --prefix client run build",
        "build:agent": "npm --prefix apps/agent run build",
        "build:all": "npm run build:shared && npm run build:server && npm run build:client && npm run build:agent",
        "test:checker": "npm --prefix packages/checker run test",
        "test:server": "npm --prefix server run test",
        "test:client": "npm --prefix client test",
        "test:agent": "npm --prefix apps/agent run test",
        "test:e2e": "npm --prefix e2e run test",
        "lint:client": "npm --prefix client run lint",
        "ci:local": "npm run check:contracts && npm run build:shared && npm run test:checker && npm run test:server && npm run build:server && npm run test:client && npm run lint:client && npm run build:client && npm run test:agent && npm run build:agent"
    },
    "workspaces": [
        "client",
        "server",
        "e2e",
        "apps/*",
        "packages/*"
    ],
    "dependencies": {
        "axios-cookiejar-support": "^6.0.5",
        "tough-cookie": "^6.0.0"
    },
    "devDependencies": {
        "vite": "^7.3.1"
    }
}
