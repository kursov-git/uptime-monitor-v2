# Required: Set a strong JWT secret
JWT_SECRET=change-me-to-a-strong-random-string

# Optional: Set initial admin password (otherwise generated randomly)
ADMIN_PASSWORD=

# Optional: Database URL (default: file:./prisma/dev.db)
DATABASE_URL=file:./prisma/dev.db

# Optional: CORS origins
# Local dev example:
CORS_ORIGINS=http://localhost:5173
# Split-runtime production example:
# CORS_ORIGINS=https://ping-agent.ru,https://www.ping-agent.ru

# Optional: public HTTPS settings for the client + certbot compose services
SSL_DOMAINS=ping-agent.ru,www.ping-agent.ru
SSL_CERT_NAME=ping-agent.ru
LETSENCRYPT_EMAIL=ops@example.com
CERTBOT_STAGING=false
SSL_WATCH_INTERVAL_SEC=60
CERTBOT_RENEW_INTERVAL_SEC=43200

# Optional: Server port and host
PORT=3000
HOST=0.0.0.0

# Optional: v2 feature flags
ENABLE_AGENT_API=true
AGENT_SSE_ENABLED=true
ENABLE_BUILTIN_WORKER=true

# Optional: Agent runtime ENV
MAIN_SERVER_URL=http://localhost:3000
AGENT_TOKEN=
AGENT_HTTP_TIMEOUT_MS=10000
AGENT_BUFFER_MAX=1000
AGENT_RESULT_MAX_BATCH=500
ENCRYPTION_KEY_1=

# Optional: 32-byte hex key for encrypting bot tokens / API keys in DB
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
