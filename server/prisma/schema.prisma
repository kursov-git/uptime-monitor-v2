generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Monitor {
  id              String  @id @default(uuid())
  name            String
  serviceName     String?
  type            String  @default("HTTP")
  url             String
  dnsRecordType   String  @default("A")
  method          String  @default("GET")
  intervalSeconds Float   @default(60)
  timeoutSeconds  Int     @default(30)
  expectedStatus  Int     @default(200)
  expectedBody    String?
  requestBody     String?
  bodyAssertionType String @default("AUTO")
  bodyAssertionPath String?
  headers         String? // JSON string

  // Auth configuration for multi-step checks
  authMethod     String  @default("NONE") // "NONE", "BASIC", "FORM_LOGIN"
  authUrl        String?
  authPayload    String? // JSON string or basic auth encoded
  authTokenRegex String?
  sslExpiryEnabled       Boolean @default(false)
  sslExpiryThresholdDays Int     @default(14)

  isActive  Boolean  @default(true)
  isPublic  Boolean  @default(false)
  agentId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agent                Agent?                       @relation(fields: [agentId], references: [id], onDelete: SetNull)
  checkResults         CheckResult[]
  notificationOverride MonitorNotificationOverride?

  @@index([agentId, isActive])
}

model CheckResult {
  id                   String   @id @default(uuid())
  monitorId            String
  monitor              Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  agentId              String?
  agent                Agent?   @relation(fields: [agentId], references: [id], onDelete: SetNull)
  resultIdempotencyKey String?  @unique
  timestamp            DateTime @default(now())
  isUp                 Boolean
  responseTimeMs       Int
  statusCode           Int?
  error                String?
  sslExpiresAt         DateTime?
  sslDaysRemaining     Int?
  sslIssuer            String?
  sslSubject           String?

  @@index([monitorId, timestamp(sort: Desc)])
  @@index([agentId, timestamp(sort: Desc)])
}

model Agent {
  id                   String    @id @default(uuid())
  name                 String
  tokenHash            String    @unique
  keyVersion           Int       @default(1)
  status               String    @default("ONLINE")
  agentVersion         String?
  heartbeatIntervalSec Int       @default(30)
  offlineAfterSec      Int       @default(90)
  lastSeen             DateTime  @default(now())
  lastSeenIp           String?
  lastSeenCountry      String?
  lastSeenCity         String?
  revokedAt            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  monitors Monitor[]
  results  CheckResult[]

  @@index([status, lastSeen])
}

// Пользователи системы
model User {
  id                  String    @id @default(uuid())
  username            String    @unique
  passwordHash        String
  role                String    @default("VIEWER")
  sessionVersion      Int       @default(0)
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  apiKey    ApiKey?
  auditLogs AuditLog[]
}

// API ключи (один на пользователя, только чтение)
model ApiKey {
  id        String    @id @default(uuid())
  key       String    @unique
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  revokedAt DateTime?
}

// Журнал действий
model AuditLog {
  id        String   @id @default(uuid())
  action    String
  details   String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  ipAddress String?
  timestamp DateTime @default(now())

  @@index([userId, timestamp(sort: Desc)])
}

// Глобальные настройки уведомлений (singleton)
model NotificationSettings {
  id String @id @default(uuid())

  appBaseUrl String?

  // Telegram
  telegramEnabled  Boolean @default(false)
  telegramBotToken String?
  telegramChatId   String?

  // Zulip
  zulipEnabled   Boolean @default(false)
  zulipBotEmail  String?
  zulipApiKey    String?
  zulipServerUrl String?
  zulipStream    String?
  zulipTopic     String?

  // Flapping protection
  flappingFailCount   Int @default(3)
  flappingIntervalSec Int @default(300)

  // Retention
  retentionDays Int @default(30)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Per-monitor notification overrides
model MonitorNotificationOverride {
  id        String  @id @default(uuid())
  monitorId String  @unique
  monitor   Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  telegramEnabled Boolean?
  telegramChatId  String?

  zulipEnabled Boolean?
  zulipStream  String?
  zulipTopic   String?

  flappingFailCount   Int?
  flappingIntervalSec Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// История уведомлений
model NotificationHistory {
  id        String   @id @default(uuid())
  monitorId String? // Optional, is null if it's a test notification
  channel   String // "TELEGRAM", "ZULIP"
  status    String // "SUCCESS", "FAILED"
  error     String? // Error message if failed
  timestamp DateTime @default(now())

  @@index([monitorId, timestamp(sort: Desc)])
}
