{
  "name": "uptime-monitor-server",
  "version": "1.0.0",
  "description": "Uptime Monitor — Backend Server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "cross-env DATABASE_URL=file:./test.db vitest run",
    "test:integration": "cross-env DATABASE_URL=file:./test.db vitest run --coverage",
    "test:watch": "cross-env DATABASE_URL=file:./test.db vitest",
    "pretest": "cross-env DATABASE_URL=file:./test.db prisma db push",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:studio": "prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/client": "^5.22.0",
    "@uptime-monitor/checker": "*",
    "@uptime-monitor/shared": "*",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "cacheable-lookup": "^7.0.0",
    "fastify": "^5.8.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^22.19.15",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.18",
    "cross-env": "^10.1.0",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
  }
}
